{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase-debug.log",
      ".firebase/**"
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
      },
      {
        "source": "**/*.html",
        "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
      }
    ]
  }
}
